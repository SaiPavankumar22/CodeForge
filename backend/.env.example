# MongoDB
MONGODB_URL=<mongodb_url>
DATABASE_NAME=<database_name>

# Admin Credentials
ADMIN_EMAIL=<email>
ADMIN_PASSWORD=<password>

# App Settings
APP_SECRET_KEY=<app_secret_key>
APP_ENV=<app_env>

# Code Execution Limits
MAX_EXECUTION_TIME=10
MAX_MEMORY_MB=256

# Optional: full paths if commands are not on PATH (typical on Windows; use forward slashes or escaped backslashes)
# PYTHON_EXECUTABLE=C:/Users/You/AppData/Local/Programs/Python/Python311/python.exe
# NODE_EXECUTABLE=C:/Program Files/nodejs/node.exe
# GPP_EXECUTABLE=C:/mingw64/bin/g++.exe
# JAVAC_EXECUTABLE=C:/Program Files/Java/jdk-21/bin/javac.exe
# JAVA_EXECUTABLE=C:/Program Files/Java/jdk-21/bin/java.exe
